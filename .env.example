# Backend (Spring Boot) — copy to .env or export before `bootRun`.
# Never commit real API keys.

# PostgreSQL
# DB_URL=jdbc:postgresql://localhost:5432/kurashdb
# DB_USERNAME=postgres
# DB_PASSWORD=

# JWT
# JWT_SECRET=

# External LLM for achievement insights (server-side only; used from application.yml app.ai.*)
AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Frontend (Vite) — optional; API URL only. Do NOT put LLM keys here (they would be exposed in the browser).
# VITE_API_BASE_URL=http://localhost:8080/api

# --- Docker (сервер): см. env.docker.example — скопируйте в .env рядом с docker-compose.yml ---
# DB_PASSWORD, JWT_SECRET, AI_API_KEY; для фронта в образе: VITE_API_BASE_URL=/api
