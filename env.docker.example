# Скопируйте на сервер рядом с docker-compose.yml:
#   cp env.docker.example .env && chmod 600 .env && nano .env
#
# Не коммитьте .env (уже в .gitignore).
#
# Без файла .env docker-compose подставит слабые значения по умолчанию из compose
# (удобно для первой сборки). На проде обязательно задайте DB_PASSWORD и JWT_SECRET ниже.
#
# VPS: после первого успешного запуска Postgres пароль в .env не меняет уже созданный том.
# Сменили DB_PASSWORD — либо верните старый, либо docker compose down -v (данные БД в Docker пропадут).

# PostgreSQL
POSTGRES_DB=kurashdb
POSTGRES_USER=postgres
DB_PASSWORD=замените_на_случайную_строку

# JWT (HMAC): не короче 32 символов, лучше 64+
JWT_SECRET=замените_на_длинную_случайную_строку_минимум_64_символа_для_продакшена

# OpenAI (опционально; без ключа AI-функции не будут работать)
AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Фронт при сборке образа: относительный путь — тот же хост, nginx проксирует /api
# VITE_API_BASE_URL=/api
