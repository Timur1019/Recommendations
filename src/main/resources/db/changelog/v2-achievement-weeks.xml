<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v2-001-achievement-training-weeks" author="cursor">
        <createTable tableName="achievement_training_weeks">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="achievement_id" type="BIGINT">
                <constraints nullable="false" referencedTableName="achievements" referencedColumnNames="id"
                             foreignKeyName="fk_atw_achievement" deleteCascade="true"/>
            </column>
            <column name="week_start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="schedule_json" type="JSONB">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_atw_achievement" tableName="achievement_training_weeks">
            <column name="achievement_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
